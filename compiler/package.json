{
  "name": "@rexscript/compiler",
  "version": "0.1.0-phase1",
  "private": true,
  "type": "module",
  "description": "Phase 1 compiler scaffolding for RexScript",
  "dependencies": {
    "@rexscript/rosetta": "file:../packages/rosetta",
    "@rexscript/runtime": "file:../packages/runtime",
    "@rexscript/xrisk": "file:../packages/xrisk"
  },
  "scripts": {
    "phase1:smoke": "node ./scripts/phase1-smoke.js",
    "rex:check": "node ./scripts/rex-check.js",
    "rex:compile": "node ./scripts/rex-compile.js",
    "rex:run": "node ./scripts/rex-run.js",
    "rex:trace": "node ./scripts/rex-trace.js",
    "rex:replay": "node ./bin/rex-replay.js",
    "rex:lint": "node ./scripts/rex-lint.js",
    "codegen:snapshots": "node ./scripts/codegen-snapshots.js",
    "codegen:snapshots:update": "node ./scripts/codegen-snapshots.js --update",
    "integration:run": "bash ../tests/integration/compile-run-trace.sh",
    "integration:trace-schema": "node ../tests/integration/validate-trace-schema.js ../tests/integration/integration_when_use_instead.trace.json",
    "integration:runtime-trace-schema": "node ../tests/integration/validate-trace-schema.js ../tests/integration/integration_when_use_instead.runtime.trace.json",
    "integration:runtime-behavior": "node ../tests/integration/runtime-behavior-check.js",
    "integration:runtime-browser-adapter": "node ../tests/integration/runtime-browser-adapter-check.js",
    "integration:host-js-boundary": "node ../tests/integration/host-js-boundary-check.js",
    "integration:compiler-surface": "node ../tests/integration/compiler-surface-check.js",
    "integration:runtime-blocked-trace": "node ../tests/integration/runtime-blocked-trace-check.js",
    "integration:compiler-policy": "node ../tests/integration/compiler-policy-check.js",
    "integration:recovery-sourcemap": "node ../tests/integration/recovery-sourcemap-check.js",
    "integration:rosetta-detection": "node ../tests/integration/rosetta-detection-check.js",
    "integration:use-instead-matrix-policy": "node ../tests/integration/use-instead-matrix-policy-check.js",
    "integration:use-instead-confidence-band": "node ../tests/integration/use-instead-confidence-band-check.js",
    "integration:use-instead-trace-consistency": "node ../tests/integration/use-instead-trace-consistency-check.js",
    "integration:use-instead-blocked-trace-consistency": "node ../tests/integration/use-instead-blocked-trace-consistency-check.js",
    "integration:use-instead-blocked-trace-schema": "node ../tests/integration/use-instead-blocked-trace-schema-check.js",
    "integration:phase3": "npm run -s integration:run && npm run -s integration:trace-schema && npm run -s integration:runtime-trace-schema && npm run -s integration:runtime-behavior && npm run -s integration:runtime-browser-adapter && npm run -s integration:runtime-trace-metadata",
    "integration:phase-b": "npm run -s integration:use-instead-matrix-policy && npm run -s integration:use-instead-confidence-band && npm run -s integration:use-instead-trace-consistency && npm run -s integration:use-instead-blocked-trace-consistency && npm run -s integration:use-instead-blocked-trace-schema",
    "integration:runtime-trace-metadata": "npm run -s integration:run && node ../tests/integration/runtime-trace-metadata-check.js",
    "integration:diagnostic-format": "node ../tests/integration/diagnostic-format-check.js",
    "integration:vscode-support": "node ../tests/integration/vscode-support-check.js",
    "integration:vscode-grammar-scopes": "node ../tests/integration/vscode-grammar-scope-check.js",
    "integration:phase-d": "npm run -s integration:vscode-support && npm run -s integration:vscode-grammar-scopes",
    "integration:phase5-policy-gate-stress": "node ../tests/integration/phase5-policy-gate-stress-check.js",
    "integration:phase5-hardening": "npm run -s integration:phase5-policy-gate-stress && npm run -s integration:dynamic-feature-lifecycle",
    "integration:dynamic-feature-lifecycle": "bash ../tests/integration/dynamic-feature-lifecycle.sh",
    "integration:full-validation": "npm run -s phase1:smoke && npm run -s codegen:snapshots && npm run -s integration:phase3 && npm run -s integration:host-js-boundary && npm run -s integration:compiler-surface && npm run -s integration:compiler-policy && npm run -s integration:recovery-sourcemap && npm run -s integration:rosetta-detection && npm run -s integration:phase-b && npm run -s integration:diagnostic-format && npm run -s integration:phase-d && npm run -s integration:phase5-hardening"
  }
}
