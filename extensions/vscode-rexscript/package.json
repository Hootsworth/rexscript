{
  "name": "rexscript-vscode-support",
  "displayName": "RexScript Language Support",
  "description": "RexScript syntax highlighting, file icons, and command palette actions.",
  "version": "1.0.9",
  "publisher": "rexscript",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hootsworth/rexscript"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:rexscript",
    "onCommand:rexscript.openMenu",
    "onCommand:rexscript.check",
    "onCommand:rexscript.compile",
    "onCommand:rexscript.run",
    "onCommand:rexscript.trace"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "rexscript",
        "aliases": [
          "RexScript",
          "rexscript"
        ],
        "extensions": [
          ".rex"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/rexscript-file.svg",
          "dark": "./icons/rexscript-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "rexscript",
        "scopeName": "source.rexscript",
        "path": "./syntaxes/rexscript.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "rexscript.openMenu",
        "title": "Open RexScript Command Menu",
        "category": "RexScript"
      },
      {
        "command": "rexscript.check",
        "title": "Check Current RexScript File",
        "category": "RexScript"
      },
      {
        "command": "rexscript.compile",
        "title": "Compile Current RexScript File",
        "category": "RexScript"
      },
      {
        "command": "rexscript.run",
        "title": "Run Current RexScript File",
        "icon": "$(play)",
        "category": "RexScript"
      },
      {
        "command": "rexscript.trace",
        "title": "Trace Current RexScript File",
        "category": "RexScript"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "rexscript.run",
          "when": "resourceExtname == .rex",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "rexscript.run",
          "when": "resourceExtname == .rex"
        }
      ],
      "commandPalette": [
        {
          "command": "rexscript.openMenu"
        },
        {
          "command": "rexscript.check",
          "when": "resourceExtname == .rex"
        },
        {
          "command": "rexscript.compile",
          "when": "resourceExtname == .rex"
        },
        {
          "command": "rexscript.run",
          "when": "resourceExtname == .rex"
        },
        {
          "command": "rexscript.trace",
          "when": "resourceExtname == .rex"
        }
      ]
    },
    "iconThemes": [
      {
        "id": "rexscript-file-icons",
        "label": "RexScript File Icons",
        "path": "./icons/rex-icon-theme.json"
      }
    ]
  }
}
